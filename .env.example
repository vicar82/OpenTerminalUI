# ============================================================================
# OpenTerminalUI — единый файл конфигурации
# ----------------------------------------------------------------------------
# Скопируйте этот файл в .env (установщик сделает это автоматически).
# Интерактивная настройка API-ключей: ./scripts/setup-keys.sh
#
# ВСЁ НЕОБЯЗАТЕЛЬНО. Приложение запускается и работает на встроенных
# резервных источниках данных без каких-либо ключей — добавляйте ключи,
# только чтобы получить доступ к полным данным.
# ============================================================================

# ----------------------------------------------------------------------------
# Ключи безопасности  (генерируются автоматически ./install.sh — оставьте
# пустыми, чтобы установщик заполнил их случайными значениями)
# ----------------------------------------------------------------------------
JWT_SECRET_KEY=
CACHE_SIGNING_KEY=

# ----------------------------------------------------------------------------
# Учётная запись администратора при первом запуске  (генерируется установщиком)
# На первом запуске создаётся администратор, чтобы можно было сразу войти.
# Повторный запуск не перезаписывает существующих пользователей.
# ----------------------------------------------------------------------------
BOOTSTRAP_ADMIN_EMAIL=admin@openterminal.local
BOOTSTRAP_ADMIN_PASSWORD=

# ----------------------------------------------------------------------------
# API-ключи поставщиков рыночных данных  (все необязательные)
# ----------------------------------------------------------------------------
# Financial Modeling Prep — акции США, фундаментал, отчётность
FMP_API_KEY=
# Finnhub — WebSocket-тики США в реальном времени
FINNHUB_API_KEY=
FINNHUB_WS_ENABLED=true
# FRED — макроэкономические ряды
FRED_API_KEY=
# Alpaca — рыночные данные США
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_FEED=iex
ALPACA_ADJUSTMENT=raw
# Zerodha Kite — Индия NSE/BSE в реальном времени + история
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=

# ----------------------------------------------------------------------------
# AI / LLM (необязательно — питает анализ новостей и эмоциональный индикатор)
# ----------------------------------------------------------------------------
AI_PROVIDER=openai
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
# OpenRouter — питает встроенного агента и эмоциональный анализ новостей
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Маршрутизация моделей агента. AGENT_PROVIDER: openrouter | openai | lmstudio.
AGENT_PROVIDER=openrouter
AGENT_MODEL=openai/gpt-oss-20b:free
AGENT_FALLBACK_MODELS=openai/gpt-oss-20b:free,qwen/qwen3-coder:free,meta-llama/llama-3.3-70b-instruct:free
AGENT_DEBATE_ENABLED=true
# LM Studio (локальная модель Gemma). Запустите LM Studio, загрузите модель
# и включите локальный сервер, затем установите LM_STUDIO_ENABLED=true.
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=google/gemma-4-26b-a4b
LM_STUDIO_ENABLED=true

# ----------------------------------------------------------------------------
# Инфраструктура / время выполнения (разумные значения по умолчанию)
# ----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
OPENTERMINALUI_SQLITE_URL=sqlite:///data/openterminalui.db
OPENTERMINALUI_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
OPENTERMINALUI_PREFETCH_ENABLED=0
CHART_CACHE_TTL=900
OHLCV_HOT_TTL_SECONDS=300
OHLCV_WARM_TTL_SECONDS=86400
OHLCV_COLD_ROOT=data/bars
