# ============================================================================
# OpenTerminalUI — single configuration file
# ----------------------------------------------------------------------------
# Copy this file to `.env` (the installer does this for you) and fill in keys.
#   cp .env.example .env
# Easiest way to add/update keys interactively:  make keys   (or ./scripts/setup-keys.sh)
#
# EVERYTHING IS OPTIONAL. The app boots and runs with built-in fallback data
# providers when no keys are present — add keys only to unlock live/full data.
# This one file is read by both the backend and Docker Compose. You do NOT
# need a separate backend/.env anymore.
# ============================================================================

# ----------------------------------------------------------------------------
# Security secrets  (auto-generated by ./install.sh — leave blank to let the
# installer fill them in with strong random values)
# ----------------------------------------------------------------------------
JWT_SECRET_KEY=
CACHE_SIGNING_KEY=

# ----------------------------------------------------------------------------
# First-run admin account  (auto-generated by ./install.sh)
# A unique admin account is seeded on first launch so you can log in
# immediately — no "user not found" errors. Credentials are printed at the
# end of the install. Change the password after first login.
# Seeding is skipped automatically once any user exists.
# ----------------------------------------------------------------------------
BOOTSTRAP_ADMIN_EMAIL=admin@openterminal.local
BOOTSTRAP_ADMIN_PASSWORD=

# ----------------------------------------------------------------------------
# Market data API keys  (all optional)
# ----------------------------------------------------------------------------
# Financial Modeling Prep — US equities, fundamentals, earnings
FMP_API_KEY=
# Finnhub — US real-time WebSocket ticks
FINNHUB_API_KEY=
FINNHUB_WS_ENABLED=true
# FRED — macro / economic series
FRED_API_KEY=
# Alpaca — US market data
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_FEED=iex
ALPACA_ADJUSTMENT=raw
# Zerodha Kite — India NSE/BSE real-time + historical
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=

# ----------------------------------------------------------------------------
# AI / LLM (optional — powers news sentiment & emotion analysis)
# ----------------------------------------------------------------------------
AI_PROVIDER=openai
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
# OpenRouter — powers the in-app agent console AND news emotion analysis
# (key starts with sk-or-...).
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Agent / emotion LLM routing. AGENT_PROVIDER: openrouter | openai | lmstudio.
# AGENT_MODEL: an OpenRouter model id (use a :free model for the free tier).
# AGENT_FALLBACK_MODELS: comma-separated free models tried in order when the
# primary is rate-limited (429) or unavailable (404). Keep all entries ":free".
AGENT_PROVIDER=openrouter
AGENT_MODEL=openai/gpt-oss-20b:free
AGENT_FALLBACK_MODELS=openai/gpt-oss-20b:free,qwen/qwen3-coder:free,meta-llama/llama-3.3-70b-instruct:free
# AGENT_DEBATE_ENABLED: enable multi-agent debate mode (analyst team -> bull/bear
# -> portfolio manager). The Agent console exposes a "Debate" toggle; set this to
# true so that toggle works. Debate runs several LLM calls per request.
AGENT_DEBATE_ENABLED=true
# LM Studio (locally hosted Gemma model). Start LM Studio, load a Gemma model,
# enable its local server, then set LM_STUDIO_ENABLED=true.
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=google/gemma-4-26b-a4b
LM_STUDIO_ENABLED=true

# ----------------------------------------------------------------------------
# Infrastructure / runtime (sensible defaults — usually no need to change)
# ----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
OPENTERMINALUI_SQLITE_URL=sqlite:///data/openterminalui.db
OPENTERMINALUI_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
OPENTERMINALUI_PREFETCH_ENABLED=0
CHART_CACHE_TTL=900
OHLCV_HOT_TTL_SECONDS=300
OHLCV_WARM_TTL_SECONDS=86400
OHLCV_COLD_ROOT=data/bars
